{
  // ── C# / OmniSharp ────────────────────────────────────────────────────
  "dotnet.defaultSolution": "TournamentMastery.csproj",
  "omnisharp.enableRoslynAnalyzers": true,
  "omnisharp.enableEditorConfigSupport": true,
  "omnisharp.enableAsyncCompletion": true,

  // ── File associations ─────────────────────────────────────────────────
  "files.associations": {
    "*.xml": "xml",
    "SubModule.xml": "xml"
  },

  // ── Editor ────────────────────────────────────────────────────────────
  "editor.formatOnSave": true,
  "editor.formatOnType": false,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.rulers": [120],
  "[csharp]": {
    "editor.defaultFormatter": "ms-dotnettools.csharp",
    "editor.formatOnSave": true
  },
  "[xml]": {
    "editor.defaultFormatter": "redhat.vscode-xml",
    "editor.formatOnSave": true
  },

  // ── File exclusions (hide build noise) ────────────────────────────────
  "files.exclude": {
    "**/bin": true,
    "**/obj": true,
    "**/.vs": true
  },
  "search.exclude": {
    "**/bin": true,
    "**/obj": true
  },

  // ── XML schema for SubModule.xml ─────────────────────────────────────
  "xml.fileAssociations": [
    {
      "pattern": "SubModule.xml",
      "systemId": "https://raw.githubusercontent.com/BUTR/Bannerlord.ModuleManager/master/src/Bannerlord.ModuleManager/ModuleInfoExtended.xsd"
    }
  ]
}
